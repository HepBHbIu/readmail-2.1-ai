# ╔══════════════════════════════════════════════════════════════╗
# ║  Readmail v2 — bootstrap-конфиг (пример)                   ║
# ║  Все настройки (включая пароли) управляются через панель:  ║
# ║  http://localhost:8001 → Настройки                         ║
# ║                                                            ║
# ║  .env нужен ТОЛЬКО для первого запуска / fallback.         ║
# ║  После сохранения в панели — SQLite перезаписывает .env.   ║
# ╚══════════════════════════════════════════════════════════════╝

# --- Пути (Docker-специфичные, не меняются через панель) ---
APP_NAME=Readmail v2
APP_VERSION=2.0.0
DATABASE_PATH=/app/data/readmail.sqlite3
BUYER_CONFIG_DIR=/app/config/buyers
ONE_C_FILE_DIR=/app/data/outbox_1c

# --- IMAP (заполняй через веб-панель!) ---
IMAP_HOST=imap.yandex.com
IMAP_PORT=993
# IMAP_USERNAME= ← вводи через панель
# IMAP_PASSWORD= ← вводи через панель (хранится в SQLite, маскируется)
IMAP_FOLDERS=INBOX
IMAP_BATCH_SIZE=5
IMAP_LIMIT=200
IMAP_TOTAL_LIMIT=2000
IMAP_TIMEOUT_SECONDS=30
IMAP_SEARCH=ALL
IMAP_READONLY=true
IMAP_MAX_RAW_EMAIL_MB=25

# --- Автоимпорт ---
SCAN_INTERVAL_SECONDS=0

# --- AI ---
ENABLE_AI=false

# --- 1С ---
ONE_C_EXPORT_MODE=file
AUTO_QUEUE_CONTROL_EVENTS=true
AUTO_DELIVER_OUTBOX=false
